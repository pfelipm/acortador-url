{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/style.css", "destination": "/style.css" },
    { "source": "/favicon.ico", "destination": "/favicon.ico" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/:slug", "destination": "/api/redirect?slug=:slug" }
  ]
}
